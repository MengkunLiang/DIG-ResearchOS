{
  "type": "object",
  "properties": {
    "version": {
      "type": "string"
    },
    "ideas": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "properties": {
          "idea": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "pitch": {
                "type": "string",
                "minLength": 1
              },
              "core_claim": {
                "type": "string",
                "minLength": 1
              },
              "target_problem": {
                "type": "string",
                "minLength": 1
              },
              "mechanism": {
                "type": "string",
                "minLength": 1
              },
              "prediction": {
                "type": "string",
                "minLength": 1
              },
              "counterfactual": {
                "type": "string",
                "minLength": 1
              },
              "mechanism_family": {
                "type": "string",
                "minLength": 1
              },
              "cdr_tuple": {
                "type": "object",
                "properties": {
                  "problem_frame": {"type": "string"},
                  "design_rationale": {"type": "string"},
                  "artifact": {"type": "string"},
                  "design_principles": {
                    "type": "array",
                    "items": {"type": "string"}
                  },
                  "data_view": {"type": "string"},
                  "evaluation_mode": {"type": "string"},
                  "contribution_type": {
                    "type": "string",
                    "enum": ["invention", "improvement", "exaptation", "routine"]
                  },
                  "boundary_conditions": {
                    "type": "array",
                    "items": {"type": "string"}
                  },
                  "cross_paper_tension": {
                    "type": "array",
                    "items": {"type": "string"}
                  }
                },
                "additionalProperties": true
              },
              "contribution_type": {
                "type": "string",
                "enum": ["invention", "improvement", "exaptation", "routine"]
              },
              "contribution_strength": {
                "type": ["integer", "number"],
                "minimum": 1,
                "maximum": 5
              }
            },
            "required": ["id", "title", "pitch", "core_claim", "target_problem", "mechanism", "prediction", "counterfactual", "mechanism_family"],
            "additionalProperties": true
          },
          "hypothesis_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^#?[Hh][0-9]+$"
            }
          },
          "source": {
            "type": "object",
            "properties": {
              "from_synthesis_section": {
                "type": "string",
                "minLength": 1
              },
              "from_missing_area": {
                "type": "string",
                "minLength": 1
              },
              "from_seed_idea": {
                "type": "boolean"
              },
              "derived_from_previous": {
                "type": ["string", "null"]
              },
              "supporting_papers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "title": {
                      "type": "string",
                      "minLength": 1
                    },
                    "claim_used": {
                      "type": "string",
                      "minLength": 1
                    },
                    "paper_id": {
                      "type": "string"
                    }
                  },
                  "required": ["title", "claim_used"],
                  "additionalProperties": true
                }
              },
              "trigger_observation": {
                "type": "string",
                "minLength": 1
              },
              "seed_alignment": {
                "type": "string",
                "description": "How this idea aligns with the user's original seed ideas or constraints. 'direct' if derived from seed, 'partial' if related, 'none' if independent."
              },
              "idea_origin": {
                "type": "string",
                "enum": [
                  "free_reasoning",
                  "seed_refinement",
                  "seed_derived",
                  "evidence_driven",
                  "synthesis_gestalt",
                  "problem_reframing",
                  "design_rationale_derivation",
                  "cross_domain_analogy",
                  "survey_driven",
                  "bridge_synthesis",
                  "mechanism_challenge",
                  "reverse_operation",
                  "subgroup_failure",
                  "missing_area_exploration",
                  "gap_exploration"
                ]
              },
              "prior_art": {
                "type": ["string", "object", "null"],
                "description": "Optional novelty grounding. 'none' is valid and can indicate high novelty with high risk."
              },
              "cross_domain_source": {
                "type": ["string", "null"],
                "description": "Deprecated compatibility alias for a single bridge_id. Prefer cross_domain_sources."
              },
              "cross_domain_sources": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "description": "Optional bridge_id list when this idea was inspired by bridge_transfer_drafts, domain_map.theory_bridge, paper_notes_bridge, or the confirmed bridge-domain plan."
              },
              "cross_domain_relation": {
                "type": ["string", "null"],
                "enum": [
                  "mechanism_bridge",
                  "method_transfer",
                  "evaluation_or_metric_bridge",
                  "baseline_or_dataset_relevance",
                  "adjacent_application",
                  null
                ],
                "description": "Relation type for cross_domain_sources. This is an LLM-authored provenance field, not a deterministic tool judgment."
              },
              "constraint_status": {
                "type": "string",
                "enum": ["mainline", "supplement", "bridge", "not_supported_by_current_evidence"]
              }
            },
            "required": [
              "from_seed_idea",
              "idea_origin",
              "constraint_status",
              "trigger_observation"
            ],
            "additionalProperties": true
          },
          "selection_rationale": {
            "type": "object",
            "properties": {
              "novelty_reason": {
                "type": "string",
                "minLength": 1
              },
              "feasibility_reason": {
                "type": "string",
                "minLength": 1
              },
              "impact_reason": {
                "type": "string",
                "minLength": 1
              },
              "evaluability_reason": {
                "type": "string",
                "minLength": 1
              },
              "paper_story": {
                "type": "string",
                "minLength": 1
              },
              "contribution_character": {
                "type": "string",
                "description": "Forward-looking answer: how the field changes if the idea works."
              }
            },
            "required": [
              "novelty_reason",
              "feasibility_reason",
              "impact_reason",
              "evaluability_reason"
            ],
            "additionalProperties": true
          },
          "closest_baselines": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "similarity": {
                  "type": "string",
                  "minLength": 1
                },
                "difference": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": ["name", "similarity", "difference"],
              "additionalProperties": true
            }
          },
          "counterfactual_check": {
            "type": "string",
            "enum": ["collapses", "survives_weakened", "independent", "insufficient_evidence"]
          },
          "counterfactual_note": {
            "type": "string"
          },
          "nearest_prior_work": {
            "type": "object",
            "properties": {
              "work": { "type": "string" },
              "distance": {
                "type": "string",
                "enum": ["very_close", "moderate", "distant", "none_found", "not_computed"]
              }
            },
            "required": ["work", "distance"],
            "additionalProperties": true
          },
          "novelty_signal": {
            "type": "string",
            "enum": ["marginal_zone", "adjacent_zone", "no_nearby_cluster", "not_computed", "domain_map_unavailable"]
          },
          "scores": {
            "type": "object",
            "properties": {
              "novelty": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "feasibility": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "impact": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "evaluability": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "differentiation": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "cost": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "contribution_strength": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              }
            },
            "required": [
              "novelty",
              "feasibility",
              "impact",
              "evaluability",
              "differentiation",
              "cost",
              "contribution_strength"
            ],
            "additionalProperties": true
          },
          "decision": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "enum": ["selected", "rejected", "deferred", "merged"]
              },
              "selected_reason": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "rejection_reason": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "selected_by": {
                "type": "string"
              },
              "user_feedback": {
                "type": "string"
              },
              "can_revisit_if": {
                "type": "string"
              }
            },
            "required": ["status"],
            "additionalProperties": true
          },
          "risks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "risk": {
                  "type": "string",
                  "minLength": 1
                },
                "early_signal": {
                  "type": "string",
                  "minLength": 1
                },
                "mitigation": {
                  "type": "string",
                  "minLength": 1
                },
                "kill_criteria": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": ["risk", "early_signal", "mitigation", "kill_criteria"],
              "additionalProperties": true
            }
          },
          "minimum_experiment": {
            "type": "object",
            "properties": {
              "dataset": {
                "type": "string",
                "minLength": 1
              },
              "baseline": {
                "type": "string",
                "minLength": 1
              },
              "metric": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "expected_signal": {
                "type": "string",
                "minLength": 1
              },
              "estimated_cost_usd": {
                "type": "number",
                "minimum": 0
              }
            },
            "required": [
              "dataset",
              "baseline",
              "metric",
              "expected_signal",
              "estimated_cost_usd"
            ],
            "additionalProperties": true
          }
        },
        "required": [
          "idea",
          "source",
          "selection_rationale",
          "counterfactual_check",
          "counterfactual_note",
          "nearest_prior_work",
          "novelty_signal",
          "scores",
          "decision",
          "risks",
          "minimum_experiment"
        ],
        "additionalProperties": true
      }
    }
  },
  "required": ["ideas"],
  "additionalProperties": true
}
