{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://researchos.dev/schemas/deep_read_queue.schema.json",
  "title": "Deep Read Queue",
  "description": "Schema for T2-produced deep-read queue records",
  "type": "object",
  "required": [
    "paper_id",
    "title",
    "relevance_score",
    "access_score_estimate",
    "access_score",
    "evidence_level",
    "seed_priority",
    "queue_rank",
    "read_priority",
    "target_bucket"
  ],
  "properties": {
    "paper_id": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "source": { "type": "string" },
    "year": { "type": ["integer", "null"] },
    "venue": { "type": "string" },
    "relevance_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "access_score_estimate": { "type": "number", "minimum": 0, "maximum": 1 },
    "access_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence_level": {
      "type": "string",
      "enum": ["FULL_TEXT", "PARTIAL_TEXT", "ABSTRACT_ONLY", "METADATA_ONLY"]
    },
    "access_level_hint": {
      "type": "string",
      "enum": ["FULL_TEXT_LOCAL", "LIKELY_FULL_TEXT", "POSSIBLE_FULL_TEXT", "ABSTRACT_OR_METADATA", "METADATA_ONLY"]
    },
    "seed_priority": { "type": "boolean" },
    "has_local_pdf": { "type": "boolean" },
    "has_seed_pdf": { "type": "boolean" },
    "seed_pdf_path": { "type": "string" },
    "why_relevant": { "type": "string" },
    "queue_reason": { "type": "string" },
    "normalized_id": { "type": "string" },
    "url": { "type": "string" },
    "doi": { "type": "string" },
    "verification_status": {
      "type": "string",
      "enum": ["retrieved", "metadata_verified", "pdf_verified", "failed_verification"]
    },
    "verification_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "read_priority": { "type": "number" },
    "search_bucket": { "type": "string" },
    "source_bucket": { "type": "string" },
    "retrieval_intent": { "type": "string" },
    "bridge_id": { "type": ["string", "null"] },
    "semantic_role": { "type": "string" },
    "relation_to_project": { "type": "string" },
    "semantic_screen": { "type": "object" },
    "cross_domain_retrieval_candidate": { "type": "boolean" },
    "cross_domain_candidate": { "type": "boolean" },
    "recalled_by_bridges": {
      "type": "array",
      "items": { "type": "string" }
    },
    "contributed_bridges": {
      "type": "array",
      "items": { "type": "string" }
    },
    "core_screen_passed": { "type": "boolean" },
    "bridge_priority": { "type": "string" },
    "bridge_must_protected_slot": { "type": "boolean" },
    "protected_slot_bonus": { "type": "number" },
    "adjacent_field": { "type": "boolean" },
    "protected_bucket_bonus": { "type": "number" },
    "protected_slot": { "type": "boolean" },
    "triaged_out": { "type": "boolean" },
    "triaged_reason": { "type": "string" },
    "queue_rank": { "type": "integer", "minimum": 1 },
    "target_bucket": {
      "type": "string",
      "enum": [
        "seed",
        "target",
        "overflow",
        "mainline_deep",
        "mainline_screened",
        "bridge_deep",
        "bridge_probe",
        "bridge_screened"
      ]
    }
  },
  "additionalProperties": true
}
