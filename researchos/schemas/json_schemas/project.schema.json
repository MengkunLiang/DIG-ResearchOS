{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://researchos.dev/schemas/project.schema.json",
  "title": "Project Configuration",
  "description": "Schema for project.yaml (T1 PI output)",
  "type": "object",
  "required": ["project_id", "research_direction", "created_at"],
  "properties": {
    "project_id": {
      "type": "string",
      "description": "Unique project identifier",
      "minLength": 1
    },
    "research_direction": {
      "type": "string",
      "description": "Research direction/topic",
      "minLength": 3
    },
    "research_question": {
      "type": "string",
      "description": "Specific research question"
    },
    "keywords": {
      "type": "array",
      "description": "Research keywords",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "constraints": {
      "type": "object",
      "description": "Project constraints",
      "properties": {
        "max_budget_usd": {
          "type": "number",
          "minimum": 0
        },
        "deadline": {
          "type": "string",
          "format": "date"
        },
        "compute_resources": {
          "type": "object",
          "properties": {
            "allow_gpu": {
              "type": "boolean"
            },
            "max_memory_gb": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "description": "Project creation timestamp",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "description": "Last update timestamp",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata"
    },
    "seed_ensemble": {
      "type": "object",
      "description": "Optional, explicitly declared seed policy for experiments; absence means unknown, not a default policy",
      "required": ["tier1_seeds", "tier2_seeds", "tier3_seeds"],
      "properties": {
        "tier1_seeds": {
          "type": "array",
          "description": "Seeds for critical experiments (headline results)",
          "items": {
            "type": "integer"
          },
          "minItems": 1
        },
        "tier2_seeds": {
          "type": "array",
          "description": "Seeds for ablation experiments",
          "items": {
            "type": "integer"
          },
          "minItems": 1
        },
        "tier3_seeds": {
          "type": "array",
          "description": "Seeds for quick tests",
          "items": {
            "type": "integer"
          },
          "minItems": 1
        }
      }
    }
  }
}
