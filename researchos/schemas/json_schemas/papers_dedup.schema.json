{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://researchos.dev/schemas/papers_dedup.schema.json",
  "title": "Deduplicated Papers",
  "description": "Schema for deduplicated paper records (T2 Scout output)",
  "type": "object",
  "required": ["id", "source", "title", "authors", "venue", "source_type", "relevance_score", "why_relevant", "abstract", "citation_count", "url"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Paper ID (arXiv ID, DOI, or S2 corpus ID)",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "description": "Data source (arxiv, semantic_scholar, crossref, europepmc, pubmed, manual, etc.)"
    },
    "canonical_id": {
      "type": "string",
      "description": "Canonical paper identifier used across downstream stages"
    },
    "preferred_id_source": {
      "type": "string",
      "description": "Which identifier family won canonicalization (arxiv, doi, source_id, title)"
    },
    "title": {
      "type": "string",
      "description": "Paper title",
      "minLength": 1
    },
    "authors": {
      "type": "array",
      "description": "List of author names (string array)",
      "items": {
        "type": "string"
      }
    },
    "year": {
      "type": ["integer", "null"],
      "description": "Publication year",
      "minimum": 1900,
      "maximum": 2100
    },
    "venue": {
      "type": "string",
      "description": "Publication venue (conference/journal)"
    },
    "source_type": {
      "type": "string",
      "description": "Source type (top_conference, journal, preprint, workshop, etc.)"
    },
    "relevance_score": {
      "type": "number",
      "description": "Relevance score (0-1)",
      "minimum": 0,
      "maximum": 1
    },
    "why_relevant": {
      "type": "string",
      "description": "Why this paper is relevant to the research"
    },
    "abstract": {
      "type": "string",
      "description": "Paper abstract"
    },
    "citation_count": {
      "type": "integer",
      "description": "Number of citations",
      "minimum": 0
    },
    "url": {
      "type": "string",
      "description": "Paper URL"
    },
    "pdf_url": {
      "type": "string",
      "description": "PDF download URL (optional)"
    },
    "doi": {
      "type": "string",
      "description": "DOI (optional)"
    },
    "provenance": {
      "type": "object",
      "description": "Minimal provenance used for audit and deterministic verification"
    },
    "verification_status": {
      "type": "string",
      "description": "Optional downstream verification status"
    }
  },
  "additionalProperties": true
}
