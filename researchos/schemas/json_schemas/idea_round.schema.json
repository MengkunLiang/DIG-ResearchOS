{
  "$id": "https://researchos.dev/schemas/idea_round.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {"type": "string"},
    "round": {"type": "integer", "minimum": 0},
    "input_population_id": {"type": "string", "minLength": 1},
    "output_population_id": {"type": "string", "minLength": 1},
    "input_fingerprint": {"type": "string", "minLength": 16},
    "run_config_fingerprint": {"type": "string", "minLength": 16},
    "completion_status": {"enum": ["completed", "partial", "failed"]}
  },
  "required": ["round", "input_population_id", "output_population_id", "input_fingerprint", "run_config_fingerprint", "completion_status"],
  "additionalProperties": true
}
