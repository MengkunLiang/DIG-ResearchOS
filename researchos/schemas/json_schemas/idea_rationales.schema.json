{
  "type": "object",
  "properties": {
    "version": {
      "type": "string"
    },
    "ideas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "idea_id": {
            "type": "string",
            "minLength": 1
          },
          "hypothesis_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^#?[Hh][0-9]+$"
            }
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "idea_summary": {
            "type": "string",
            "minLength": 1
          },
          "basis": {
            "type": "object",
            "properties": {
              "source_questions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "literature_observations": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "claim": {
                      "type": "string",
                      "minLength": 1
                    },
                    "source": {
                      "type": "string",
                      "minLength": 1
                    },
                    "strength": {
                      "type": "string",
                      "enum": ["direct", "indirect", "weak"]
                    }
                  },
                  "required": ["claim", "source"],
                  "additionalProperties": true
                }
              },
              "missing_area_links": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "comparison_table_signals": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "seed_idea_links": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "lens_insights": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": ["literature_observations"],
            "additionalProperties": true
          },
          "reasoning": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "limitations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "idea_id",
          "hypothesis_refs",
          "title",
          "idea_summary",
          "basis",
          "reasoning",
          "confidence"
        ],
        "additionalProperties": true
      }
    }
  },
  "required": ["ideas"],
  "additionalProperties": true
}
