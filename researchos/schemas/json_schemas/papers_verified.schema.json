{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://researchos.dev/schemas/papers_verified.schema.json",
  "title": "Verified Papers",
  "description": "Schema for T2 papers that passed deterministic metadata verification",
  "type": "object",
  "required": [
    "id",
    "canonical_id",
    "source",
    "title",
    "authors",
    "year",
    "venue",
    "source_type",
    "relevance_score",
    "why_relevant",
    "abstract",
    "citation_count",
    "url",
    "verification_status",
    "verification_method",
    "verification_source",
    "verification_confidence"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "canonical_id": { "type": "string", "minLength": 1 },
    "preferred_id_source": { "type": "string" },
    "source": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "authors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "year": { "type": "integer", "minimum": 1900, "maximum": 2100 },
    "venue": { "type": "string" },
    "source_type": { "type": "string" },
    "relevance_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "why_relevant": { "type": "string" },
    "abstract": { "type": "string" },
    "citation_count": { "type": "integer", "minimum": 0 },
    "url": { "type": "string" },
    "doi": { "type": "string" },
    "externalIds": { "type": "object" },
    "provenance": { "type": "object" },
    "verification_status": {
      "type": "string",
      "enum": ["metadata_verified", "pdf_verified"]
    },
    "verification_method": { "type": "string" },
    "verification_source": { "type": "string" },
    "verification_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "verification_title_similarity": { "type": "number", "minimum": 0, "maximum": 1 },
    "verification_year_match": { "type": "boolean" }
  },
  "additionalProperties": true
}
