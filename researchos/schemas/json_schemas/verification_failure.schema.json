{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://researchos.dev/schemas/verification_failure.schema.json",
  "title": "Verification Failure",
  "description": "Schema for T2 verification failures",
  "type": "object",
  "required": [
    "paper_id",
    "title",
    "verification_status",
    "failure_reason"
  ],
  "properties": {
    "paper_id": { "type": "string", "minLength": 1 },
    "canonical_id": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "source": { "type": "string" },
    "doi": { "type": "string" },
    "verification_status": {
      "type": "string",
      "enum": ["failed_verification"]
    },
    "verification_method": { "type": "string" },
    "failure_reason": { "type": "string", "minLength": 1 },
    "verification_error": { "type": "string" },
    "verification_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": true
}
