      "basis": {
        "source_questions": ["Q1"],
        "literature_observations": [
          {
            "claim": "现有方法在长上下文或低资源约束下表现下降",
            "source": "synthesis.md: Q1 / [p3]",
            "strength": "direct"
          }
        ],
        "forward_reasoning": "从问题结构出发推导为什么该 design rationale 应成立；如果 idea 与现有文献正交，这里是主要依据",
