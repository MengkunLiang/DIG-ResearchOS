# ResearchOS Docker Mode environment.
# Copy to deploy/.env and uncomment/fill only the providers you use.
# Do not commit deploy/.env.
#
# Docker Mode uses the same non-secret config/user_settings.yaml as Native
# Mode. This file is only for secrets, image tags, and local Docker overrides.
#
# Compose also reads ../.env when it exists. Keeping values commented here
# prevents an unchanged deploy/.env from overriding working root-level secrets
# with empty strings.

# Image tag. Pin a version tag for formal projects instead of latest.
RESEARCHOS_IMAGE=researchos/system:latest

# Linux file ownership for bind-mounted workspace.
# The wrapper scripts set these automatically when possible. Direct Compose
# defaults to 0:0 for compatibility unless you uncomment these.
# RESEARCHOS_UID=1000
# RESEARCHOS_GID=1000

# LLM providers
# SILICONFLOW_API_KEY=
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=

# Literature APIs
# S2_API_KEY=
# ELSEVIER_API_KEY=
# ELSEVIER_INSTTOKEN=
# RESEARCHER_EMAIL=your-email@example.com

# Optional integrations
# GITHUB_TOKEN=
