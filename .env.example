# ResearchOS 环境变量配置示例
# 复制此文件为 .env 并填入实际的配置值
#
# 快速开始：
#   python -m researchos.cli configure-llm
# 该命令会创建 config/model_settings.yaml，并可将 API key 写入本文件。
#
# 注意：
# - .env 文件包含敏感信息，不应提交到版本控制系统
# - .env 文件已在 .gitignore 中排除
# - 保持此文件只含变量名、默认 URL 和示例值；不要在 YAML、README 或 workspace 中复制真实密钥

# ========================================
# LLM API 配置
# ========================================
# model_settings.yaml 中可写 `${DEEPSEEK_API_KEY}` 一类占位符，也可以直接
# 保存本地 key。所有 Agent 和 Skill 只使用 model_settings.yaml 声明的一条连接。

# SiliconFlow API（可选）
# 获取方式：https://siliconflow.cn
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# DeepSeek API（可选）
# 获取方式：https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenRouter API（可选）
# 获取方式：https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenAI API（可选）
# 获取方式：https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API Key（可选，如果使用 Claude 模型）
# 获取方式：https://console.anthropic.com/
ANTHROPIC_API_KEY=

# 其他 provider（按所选 model_settings.yaml 的 provider 填写；可选）
GEMINI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
CEREBRAS_API_KEY=
NVIDIA_API_KEY=
MOONSHOT_API_KEY=
ZHIPUAI_API_KEY=
DASHSCOPE_API_KEY=
MINIMAX_API_KEY=

# ========================================
# 论文搜索 API 配置（可选）
# ========================================

# Semantic Scholar API Key（可选）
# 用于：T2 Scout Agent 的学术论文搜索
# 获取方式：https://www.semanticscholar.org/product/api
S2_API_KEY=

# Elsevier API Key（可选）
# 用于：T2 Scout Agent 的 Elsevier Scopus 搜索
# 获取方式：https://dev.elsevier.com/
ELSEVIER_API_KEY=

# Elsevier 机构令牌（可选）
# 有机构授权时用于扩大 Scopus API 访问权限
ELSEVIER_INSTTOKEN=

# 研究者邮箱（可选）
# 用于：Crossref/arXiv 等文献 API 识别（礼貌性标识）
RESEARCHER_EMAIL=

# ========================================
# MCP 工具配置（可选）
# ========================================

# GitHub Personal Access Token（可选）
# 用于：GitHub MCP 服务器
# 获取方式：https://github.com/settings/tokens
GITHUB_TOKEN=

# ========================================
# 运行参数说明
# ========================================
# `config/system_config/` 保存版本化的系统默认值，不是普通用户日常配置入口。
# 若维护 runtime 本身，才会调整 logging、debug、UI 或 web-fetch 默认值。
#
# `.env` 里建议只保留：
# - API Key / Token
# - 研究者身份类信息（如 RESEARCHER_EMAIL）
# - 少量必须通过环境变量注入给第三方进程的值

# ========================================
# Docker Mode 本地覆盖（可选）
# ========================================
# Docker Compose 也读取同一份根目录 .env。deploy/ 下不再维护第二份 .env。

# 镜像 tag。正式项目建议固定版本 tag，而不是长期使用 latest。
RESEARCHOS_IMAGE=researchos/system:latest

# Linux bind mount 文件归属。deploy/researchos.sh 会自动设置当前用户；
# 直接 docker compose 时如需非 root 写入，可取消注释并填写。
# RESEARCHOS_UID=1000
# RESEARCHOS_GID=1000

# 宿主机 workspace 提示路径。通常不需要手动设置。
# RESEARCHOS_HOST_WORKSPACE_ROOT=./workspace
