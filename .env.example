# ResearchOS 环境变量配置示例
# 复制此文件为 .env 并填入实际的配置值
#
# 快速开始：
#   cp .env.example .env
#   nano .env  # 编辑并填入你的 API Key
#
# 注意：
# - .env 文件包含敏感信息，不应提交到版本控制系统
# - .env 文件已在 .gitignore 中排除

# ========================================
# LLM API 配置（必需）
# ========================================

# OpenAI API 配置
# 用于：所有 Agent 的 LLM 调用
# 获取方式：https://platform.openai.com/api-keys
# 支持：OpenAI 官方 API 或兼容的第三方服务
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API Key（可选，如果使用 Claude 模型）
# 获取方式：https://console.anthropic.com/
ANTHROPIC_API_KEY=

# 第三方 OpenAI 兼容服务示例：
# OPENAI_API_KEY=your-api-key
# OPENAI_BASE_URL=https://your-service.com/v1

# ========================================
# 论文搜索 API 配置（可选）
# ========================================

# Semantic Scholar API Key（可选）
# 用于：T2 Scout Agent 的学术论文搜索
# 获取方式：https://www.semanticscholar.org/product/api
# 注意：提高搜索速率限制，推荐申请
S2_API_KEY=

# 研究者邮箱（可选）
# 用于：arXiv API 识别（礼貌性标识）
RESEARCHER_EMAIL=your-email@example.com

# ========================================
# MCP 工具配置（可选）
# ========================================

# GitHub Personal Access Token（可选）
# 用于：GitHub MCP 服务器（代码搜索、仓库管理）
# 获取方式：https://github.com/settings/tokens
# 权限要求：repo, read:org（根据需要选择）
GITHUB_TOKEN=

# ========================================
# 系统配置（可选）
# ========================================

# 是否禁用启动横幅（0=显示，1=禁用）
RESEARCHOS_NO_BANNER=0

# Log Level 覆盖（可选）
# 用于：覆盖 runtime.yaml 中的日志级别
# 可选值：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ========================================
# 开发和调试配置（可选）
# ========================================

# 开发模式（可选）
# 启用后会显示更详细的错误信息和调试输出
DEV_MODE=false

# 启用 Trace（可选）
# 覆盖 runtime.yaml 中的 debug.enable_trace 配置
ENABLE_TRACE=true

# ========================================
# 数据库配置（未来扩展，暂未使用）
# ========================================

# PostgreSQL 配置（预留）
# 用于：持久化存储研究数据和元数据
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=researchos
# DB_USER=researchos
# DB_PASSWORD=your-db-password

# Redis 配置（预留）
# 用于：缓存和任务队列
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password

# ========================================
# 监控和日志配置（未来扩展，暂未使用）
# ========================================

# Sentry DSN（可选）
# 用于：错误追踪和监控
# SENTRY_DSN=your-sentry-dsn
