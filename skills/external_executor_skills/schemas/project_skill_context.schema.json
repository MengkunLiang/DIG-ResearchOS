  "$defs": {
    "stringOrNull": {
      "type": [
        "string",
        "null"
      ]
    },
    "pathOrNull": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^(?!/)(?!.*\\.\\./).*$"
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "objectList": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "object": {
      "type": "object"
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "fieldMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "sources"
      ],
      "properties": {
        "status": {
          "enum": [
            "confirmed",
            "confirmed_from_source",
            "uncertain"
          ]
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "note": {
          "type": "string"
        },
        "handoff_value_ignored": {}
      }
    }
