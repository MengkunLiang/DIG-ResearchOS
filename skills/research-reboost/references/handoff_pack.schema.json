{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://researchos.local/schemas/external_executor_handoff.v1.schema.json",
  "title": "ResearchOS External Executor Handoff Pack",
  "description": "Normative contract produced by the ResearchOS T5 reboost module. Method intent is compiled inside reboost and remains draft-only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "generated_at",
    "generation_status",
    "project",
    "source_manifest",
    "context_reboost",
    "method_intent",
    "baseline_matrix",
    "claim_evidence_matrix",
    "minimum_experiment_loop",
    "iteration_budget",
    "claim_boundaries",
    "writer_handoff_contract",
    "execution_contract",
    "unresolved_items",
    "validation_summary"
  ],
  "properties": {
    "schema_version": {
      "const": "external_executor_handoff.v1"
    },
    "pack_id": {
      "$ref": "#/$defs/id"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "generation_status": {
      "enum": ["completed", "needs_review", "blocked"]
    },
    "project": {
      "$ref": "#/$defs/project"
    },
    "source_manifest": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_entry"
      }
    },
    "context_reboost": {
      "$ref": "#/$defs/context_reboost"
    },
    "method_intent": {
      "$ref": "#/$defs/method_intent"
    },
    "baseline_matrix": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/baseline"
      }
    },
    "claim_evidence_matrix": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "minimum_experiment_loop": {
      "$ref": "#/$defs/minimum_experiment_loop"
    },
    "iteration_budget": {
      "$ref": "#/$defs/iteration_budget"
    },
    "claim_boundaries": {
      "$ref": "#/$defs/claim_boundaries"
    },
    "writer_handoff_contract": {
      "$ref": "#/$defs/writer_handoff_contract"
    },
    "execution_contract": {
      "$ref": "#/$defs/execution_contract"
    },
    "resource_acquisition_policy": {
      "type": "object",
      "additionalProperties": true
    },
    "paper_card_evidence_index": {
      "$ref": "#/$defs/relative_path"
    },
    "paper_card_evidence_policy": {
      "type": "object",
      "additionalProperties": true
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/unresolved_item"
      }
    },
    "validation_summary": {
      "$ref": "#/$defs/validation_summary"
    },
    "extensions": {
      "type": "object",
      "description": "Backward-compatible project or future fields. Core semantics must not be overridden here.",
      "additionalProperties": true
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "string_list": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "non_empty_string_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{1,127}$"
    },
    "id_list": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "locator", "note", "support_type"],
      "properties": {
        "source_id": {
          "$ref": "#/$defs/id"
        },
        "locator": {
          "$ref": "#/$defs/non_empty_string"
        },
        "note": {
          "$ref": "#/$defs/non_empty_string"
        },
        "support_type": {
          "enum": ["direct", "reconciled", "inferred"]
        }
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_ref"
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "title", "research_area", "task_type", "workspace_root"],
      "properties": {
        "project_id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "research_area": {
          "$ref": "#/$defs/non_empty_string"
        },
        "task_type": {
          "$ref": "#/$defs/non_empty_string"
        },
        "workspace_root": {
          "const": "."
        }
      }
    },
    "source_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "path",
        "category",
        "requirement",
        "availability",
        "used",
        "purpose",
        "precedence",
        "used_for"
      ],
      "properties": {
        "source_id": {
          "$ref": "#/$defs/id"
        },
        "path": {
          "$ref": "#/$defs/relative_path"
        },
        "category": {
          "enum": [
            "project",
            "literature_synthesis",
            "synthesis_workbench",
            "domain_map",
            "comparison_table",
            "hypotheses",
            "experiment_plan",
            "idea_scorecard",
            "risks",
            "novelty_audit",
            "research_dossier",
            "research_proposal",
            "validation_map",
            "contribution_hypothesis_map",
            "paper_note",
            "bridge_paper_note",
            "cross_domain_catalog",
            "abstract_note",
            "resource",
            "user_seed",
            "pre_novelty_context",
            "other"
          ]
        },
        "requirement": {
          "enum": ["required", "optional_backtrack"]
        },
        "availability": {
          "enum": ["available", "missing", "unreadable", "malformed"]
        },
        "used": {
          "type": "boolean"
        },
        "purpose": {
          "$ref": "#/$defs/non_empty_string"
        },
        "precedence": {
          "type": "integer",
          "minimum": 1
        },
        "used_for": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "project_scope",
              "research_goal",
              "hypothesis",
              "method_mechanism",
              "novelty_boundary",
              "baseline_selection",
              "experiment_protocol",
              "claim_boundary",
              "risk_analysis",
              "resource_hint",
              "writer_contract"
            ]
          }
        },
        "content_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "omission_reason": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "sourced_statement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "source_refs"],
      "properties": {
        "statement": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_refs": {
          "$ref": "#/$defs/source_refs"
        }
      }
    },
    "project_goal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "success_criteria", "out_of_scope", "source_refs"],
      "properties": {
        "statement": {
          "$ref": "#/$defs/non_empty_string"
        },
        "success_criteria": {
          "$ref": "#/$defs/non_empty_string_list"
        },
        "out_of_scope": {
          "$ref": "#/$defs/string_list"
        },
        "source_refs": {
          "$ref": "#/$defs/source_refs"
        }
      }
    },
    "central_hypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hypothesis_id",
        "statement",
        "causal_rationale",
        "assumptions",
        "falsification_criteria",
        "source_refs"
      ],
      "properties": {
        "hypothesis_id": {
          "$ref": "#/$defs/id"
        },
        "statement": {
          "$ref": "#/$defs/non_empty_string"
        },
        "causal_rationale": {
          "$ref": "#/$defs/non_empty_string"
        },
        "assumptions": {
          "$ref": "#/$defs/non_empty_string_list"
        },
        "falsification_criteria": {
          "$ref": "#/$defs/non_empty_string_list"
        },
        "source_refs": {
          "$ref": "#/$defs/source_refs"
        }
      }
    },
    "study_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_setting", "tasks", "datasets", "metrics", "constraints", "exclusions", "source_refs"],
      "properties": {
        "target_setting": {
          "$ref": "#/$defs/non_empty_string"
        },
        "tasks": {
          "$ref": "#/$defs/non_empty_string_list"
        },
        "datasets": {
          "$ref": "#/$defs/string_list"
        },
        "metrics": {
          "$ref": "#/$defs/string_list"
        },
        "constraints": {
          "$ref": "#/$defs/string_list"
        },
        "exclusions": {
          "$ref": "#/$defs/string_list"
        },
        "source_refs": {
          "$ref": "#/$defs/source_refs"
        }
      }
    },
    "mechanism_invariant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["invariant_id", "statement", "rationale", "source_refs"],
      "properties": {
        "invariant_id": {
          "$ref": "#/$defs/id"
        },
        "statement": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_refs": {
          "$ref": "#/$defs/source_refs"
        }
      }
    },
    "method_mechanism": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "core_mechanism",
        "contribution_intent",
        "mechanism_invariants",
        "must_preserve_module_ids",
        "candidate_module_ids",
        "source_refs"
      ],
      "properties": {
        "core_mechanism": {
          "$ref": "#/$defs/non_empty_string"
        },
        "contribution_intent": {
          "$ref": "#/$defs/non_empty_string"
        },
        "mechanism_invariants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/mechanism_invariant"
          }
        },
        "must_preserve_module_ids": {
          "$ref": "#/$defs/id_list"
        },
        "candidate_module_ids": {
          "$ref": "#/$defs/id_list"
        },
        "source_refs": {
          "$ref": "#/$defs/source_refs"
        }
      }
    },
    "novelty_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "nearest_work", "distinguishing_mechanism", "required_baseline_ids", "claim_constraints", "source_refs"],
      "properties": {
        "status": {
          "enum": ["aligned", "mismatch", "no_explicit_requirements", "unavailable"]
        },
        "nearest_work": {
          "$ref": "#/$defs/string_list"
        },
        "distinguishing_mechanism": {
          "$ref": "#/$defs/non_empty_string"
        },
        "required_baseline_ids": {
          "$ref": "#/$defs/id_list"
        },
        "claim_constraints": {
          "$ref": "#/$defs/string_list"
        },
        "source_refs": {
          "$ref": "#/$defs/source_refs"
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk_id", "category", "description", "likelihood", "impact", "mitigation", "source_refs"],
      "properties": {
        "risk_id": {
          "$ref": "#/$defs/id"
        },
        "category": {
          "enum": ["scientific", "novelty", "data", "evaluation", "fairness", "resource", "implementation", "reproducibility", "scope"]
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        },
        "likelihood": {
          "enum": ["low", "medium", "high", "unknown"]
        },
        "impact": {
          "enum": ["low", "medium", "high", "blocking"]
        },
        "mitigation": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_refs": {
          "$ref": "#/$defs/source_refs"
        }
      }
    },
    "context_mismatch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mismatch_id",
        "severity",
        "topic",
        "conflicting_statements",
        "resolution_status",
        "selected_resolution",
        "rationale",
        "affected_fields",
        "requires_human_review",
        "source_refs"
      ],
      "properties": {
        "mismatch_id": {
          "$ref": "#/$defs/id"
        },
        "severity": {
          "enum": ["warning", "material", "blocking"]
        },
        "topic": {
          "$ref": "#/$defs/non_empty_string"
        },
        "conflicting_statements": {
          "$ref": "#/$defs/non_empty_string_list"
        },
        "resolution_status": {
          "enum": ["resolved_by_precedence", "needs_review", "blocked"]
        },
        "selected_resolution": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        },
        "affected_fields": {
          "$ref": "#/$defs/non_empty_string_list"
        },
        "requires_human_review": {
          "type": "boolean"
        },
        "source_refs": {
          "$ref": "#/$defs/source_refs"
        }
      }
    },
    "context_reboost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_goal",
        "research_question",
        "central_hypothesis",
        "research_context",
        "study_scope",
        "method_mechanism",
        "novelty_audit_resolution",
        "execution_priorities",
        "risk_register",
        "known_context_mismatches"
      ],
      "properties": {
        "project_goal": {
          "$ref": "#/$defs/project_goal"
        },
        "research_question": {
          "$ref": "#/$defs/sourced_statement"
        },
        "central_hypothesis": {
          "$ref": "#/$defs/central_hypothesis"
        },
        "research_context": {
          "$ref": "#/$defs/research_context"
        },
        "resource_discovery_context": {
          "$ref": "#/$defs/resource_discovery_context"
        },
        "study_scope": {
          "$ref": "#/$defs/study_scope"
        },
        "method_mechanism": {
          "$ref": "#/$defs/method_mechanism"
        },
        "novelty_audit_resolution": {
          "$ref": "#/$defs/novelty_resolution"
        },
        "execution_priorities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["priority", "objective", "rationale", "source_refs"],
            "properties": {
              "priority": {
                "type": "integer",
                "minimum": 1
              },
              "objective": {
                "$ref": "#/$defs/non_empty_string"
              },
              "rationale": {
                "$ref": "#/$defs/non_empty_string"
              },
              "source_refs": {
                "$ref": "#/$defs/source_refs"
              }
            }
          }
        },
        "risk_register": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/risk"
          }
        },
        "known_context_mismatches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/context_mismatch"
          }
        }
      }
    },
    "research_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "research_problem",
        "scholarly_stakes",
        "practical_implications",
        "commercial_implications",
        "stakeholders_or_processes",
        "contribution_intent",
        "evidence_status",
        "proposal_context",
        "source_refs"
      ],
      "properties": {
        "research_problem": {
          "$ref": "#/$defs/non_empty_string"
        },
        "scholarly_stakes": {
          "$ref": "#/$defs/non_empty_string_list"
        },
        "practical_implications": {
          "$ref": "#/$defs/string_list"
        },
        "commercial_implications": {
          "$ref": "#/$defs/string_list"
        },
        "stakeholders_or_processes": {
          "$ref": "#/$defs/string_list"
        },
        "contribution_intent": {
          "$ref": "#/$defs/non_empty_string_list"
        },
        "evidence_status": {
          "enum": ["source_supported", "proposed_not_verified", "unknown"]
        },
        "proposal_context": {
          "$ref": "#/$defs/proposal_context"
        },
        "source_refs": {
          "$ref": "#/$defs/source_refs"
        }
      }
    },
    "proposal_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "manifest_path", "source_type", "planning_status", "summary", "t5_role", "source_refs"],
      "properties": {
        "path": {"$ref": "#/$defs/relative_path"},
        "manifest_path": {"type": "string"},
        "source_type": {"enum": ["formal_proposal", "legacy_formalization_fallback"]},
        "planning_status": {"enum": ["formalized_after_novelty_pass", "legacy_fallback"]},
        "summary": {"$ref": "#/$defs/non_empty_string"},
        "t5_role": {"const": "planning_context_not_results"},
        "source_refs": {"$ref": "#/$defs/source_refs"}
      }
    },
    "resource_discovery_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "catalog_path",
        "summary_path",
        "record_count",
        "paper_count",
        "by_resource_type",
        "t5_role",
        "evidence_boundary",
        "source_refs"
      ],
      "properties": {
        "catalog_path": {"$ref": "#/$defs/relative_path"},
        "summary_path": {"$ref": "#/$defs/relative_path"},
        "record_count": {"type": "integer", "minimum": 0},
        "paper_count": {"type": "integer", "minimum": 0},
        "by_resource_type": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
        "t5_role": {"const": "discovery_context_for_phase_b_not_execution_evidence"},
        "evidence_boundary": {"$ref": "#/$defs/non_empty_string"},
        "source_refs": {"$ref": "#/$defs/source_refs"}
      }
    },
    "method_module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module_id",
        "name",
        "classification",
        "intended_role",
        "mechanism",
        "expected_inputs",
        "expected_outputs",
        "depends_on_module_ids",
        "why_it_may_help",
        "implementation_constraints",
        "related_claim_ids",
        "planned_ablation_ids",
        "source_refs"
      ],
      "properties": {
        "module_id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "classification": {
          "enum": ["core", "candidate", "supporting"]
        },
        "intended_role": {
          "$ref": "#/$defs/non_empty_string"
        },
        "mechanism": {
          "$ref": "#/$defs/non_empty_string"
        },
        "expected_inputs": {
          "$ref": "#/$defs/non_empty_string_list"
        },
        "expected_outputs": {
          "$ref": "#/$defs/non_empty_string_list"
        },
        "depends_on_module_ids": {
          "$ref": "#/$defs/id_list"
        },
        "why_it_may_help": {
          "$ref": "#/$defs/non_empty_string"
        },
        "implementation_constraints": {
          "$ref": "#/$defs/string_list"
        },
        "related_claim_ids": {
          "$ref": "#/$defs/id_list"
        },
        "planned_ablation_ids": {
          "$ref": "#/$defs/id_list"
        },
        "source_refs": {
          "$ref": "#/$defs/source_refs"
        }
      }
    },
    "algorithm_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step_id", "order", "description", "module_ids", "inputs", "outputs"],
      "properties": {
        "step_id": {
          "$ref": "#/$defs/id"
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        },
        "module_ids": {
          "$ref": "#/$defs/id_list"
        },
        "inputs": {
          "$ref": "#/$defs/non_empty_string_list"
        },
        "outputs": {
          "$ref": "#/$defs/non_empty_string_list"
        }
      }
    },
    "allowed_refinement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["refinement_id", "description", "boundary", "review_requirement"],
      "properties": {
        "refinement_id": {
          "$ref": "#/$defs/id"
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        },
        "boundary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "review_requirement": {
          "enum": ["none", "reviewer_approval", "human_approval"]
        }
      }
    },
    "forbidden_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["change_type", "description", "required_action"],
      "properties": {
        "change_type": {
          "enum": [
            "replace_core_mechanism",
            "drop_required_baseline",
            "change_task_or_benchmark",
            "change_contribution_type",
            "weaken_evaluation_fairness",
            "promote_engineering_trick",
            "other_scope_change"
          ]
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        },
        "required_action": {
          "enum": ["reviewer_approval", "human_review", "rerun_novelty", "block_execution"]
        }
      }
    },
    "ablation_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ablation_id",
        "mechanism",
        "module_ids",
        "planned_test",
        "control",
        "expected_if_supported",
        "expected_if_not_supported",
        "related_claim_ids"
      ],
      "properties": {
        "ablation_id": {
          "$ref": "#/$defs/id"
        },
        "mechanism": {
          "$ref": "#/$defs/non_empty_string"
        },
        "module_ids": {
          "$ref": "#/$defs/id_list"
        },
        "planned_test": {
          "$ref": "#/$defs/non_empty_string"
        },
        "control": {
          "$ref": "#/$defs/non_empty_string"
        },
